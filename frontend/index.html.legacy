<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>3D IC Layout Tool</title>
  <link rel="stylesheet" href="css/style.css" />
</head>
<body>

  <!-- ═══════════════════════════════════════════════════════════════════
       TOP BAR  — title, session info, save / export buttons
  ════════════════════════════════════════════════════════════════════ -->
  <header id="topbar">
    <h1>🔬 3D IC Layout Tool</h1>
    <span id="session-label">Session: —</span>
    <div id="topbar-actions">
      <button id="btn-save">💾 Save</button>
      <button id="btn-export">📦 Export JSON</button>
      <button id="btn-new-session">🆕 New Session</button>
    </div>
  </header>

  <!-- ═══════════════════════════════════════════════════════════════════
       MAIN CONTENT — three-column flex layout
  ════════════════════════════════════════════════════════════════════ -->
  <div id="app">

    <!-- ─────────────────────────── LEFT PANEL ─────────────────────────── -->
    <aside id="panel-left">

      <!-- Layer selector -->
      <section class="panel-section">
        <h2>Layers</h2>
        <!--
          Buttons are generated automatically from CONFIG.layers in main.js.
          To add or remove a layer, edit CONFIG.layers in js/config.js.
        -->
        <div id="layer-buttons"></div>
      </section>

      <!-- Net (signal) selector -->
      <section class="panel-section">
        <h2>Active Net</h2>
        <!--
          Options are generated from CONFIG.nets in main.js.
          To add or rename a net, edit CONFIG.nets in js/config.js.
        -->
        <select id="net-select"></select>
        <!-- Colour swatch that reflects the selected net's colour -->
        <div id="net-color-swatch"></div>
      </section>

      <!-- Drawing tools -->
      <section class="panel-section">
        <h2>Tools</h2>
        <!--
          data-tool must match one of: 'wire' | 'via' | 'delete'
          The active class is managed by setTool() in main.js.
        -->
        <div id="tool-buttons">
          <button class="tool-btn active" data-tool="wire">🖊&ensp;Wire</button>
          <button class="tool-btn"        data-tool="via">⬡&ensp;Via</button>
          <button class="tool-btn"        data-tool="delete">✕&ensp;Delete</button>
        </div>
        <button id="btn-undo" class="action-btn">↩&ensp;Undo</button>
      </section>

      <!-- Auto-routing -->
      <section class="panel-section">
        <h2>Auto-Route</h2>
        <button id="btn-autoroute-net" class="action-btn">▶ Route Active Net</button>
        <button id="btn-autoroute-all" class="action-btn">▶▶ Route All Nets</button>
      </section>

      <!-- Design Rule Check -->
      <section class="panel-section">
        <h2>Design Rule Check</h2>
        <button id="btn-drc" class="action-btn">▶ Run DRC</button>
        <!-- Score shown here after DRC runs (e.g. "80/100") -->
        <div id="drc-score"></div>
      </section>

    </aside><!-- #panel-left -->

    <!-- ─────────────────────────── CANVAS AREA ──────────────────────── -->
    <main id="canvas-wrap">

      <!-- Info bar above the canvas -->
      <div id="canvas-info">
        <span id="info-layer">Layer: M1 (horizontal)</span>
        <span id="info-cursor">Cursor: —</span>
        <span id="info-hint">Initialising…</span>
      </div>

      <!--
        The <canvas> element.  Its pixel size is set by CanvasRenderer in
        canvas.js (derived from CONFIG.grid and CONFIG.display.cellSize).
        Do NOT set width/height here — they are controlled by JavaScript.
      -->
      <canvas id="main-canvas" class="tool-wire"></canvas>

    </main><!-- #canvas-wrap -->

    <!-- ─────────────────────────── RIGHT PANEL ──────────────────────── -->
    <aside id="panel-right">

      <!-- DRC violation list -->
      <section class="panel-section" id="section-drc">
        <h2>DRC Violations</h2>
        <div id="drc-violations">
          <p class="dim">Run DRC to see results.</p>
        </div>
      </section>

      <!-- Past sessions -->
      <section class="panel-section" id="section-sessions">
        <h2>Past Sessions</h2>
        <div id="sessions-list">
          <p class="dim">Loading…</p>
        </div>
      </section>

    </aside><!-- #panel-right -->

  </div><!-- #app -->

  <!-- ═══════════════════════════════════════════════════════════════════
       SCRIPTS — must be loaded in this exact order.
       config.js first (defines CONFIG), then the rest.
  ════════════════════════════════════════════════════════════════════ -->
  <script src="js/config.js"></script>  <!-- ← Edit this file to customise -->
  <script src="js/api.js"></script>
  <script src="js/canvas.js"></script>
  <script src="js/main.js"></script>

</body>
</html>
